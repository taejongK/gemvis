# Gemvis 환경 변수 — cp .env.example .env 로 복사 후 편집
# (./scripts/setup.sh 가 .env 가 없으면 자동 생성)

# LLM 엔드포인트 (OpenAI 호환: llama-server / vLLM)
LLM_BASE_URL=http://127.0.0.1:8080/v1
LLM_API_KEY=none
LLM_MODEL=unsloth/gemma-4-E2B-it-GGUF:Q4_K_M

# 감시 폴더 (기본: ~/gemvis_watch)
GEMVIS_WATCH_DIR=

# 그래프/임베딩 저장 경로 (기본: ~/.gemvis/)
# GEMVIS_GRAPH_PATH=~/.gemvis/graph.ttl
# GEMVIS_EMBEDDINGS_PATH=~/.gemvis/embeddings.npz

# (선택) Google Gemini API 사용 시. 프라이버시 룰상 비활성 권장.
# GOOGLE_API_KEY=
